<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PathOfAvalonia.TreeApp.ViewModels"
             x:Class="PathOfAvalonia.TreeApp.EquipmentView"
             x:DataType="vm:EquipmentViewModel"
             Background="#101018">
    <Grid>
        <TextBlock Text="{Binding EmptyMessage}"
                   IsVisible="{Binding !HasItems}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#AAAACC" FontSize="16"/>

        <ScrollViewer IsVisible="{Binding HasItems}">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ItemGroupViewModel">
                        <StackPanel Margin="8,10,8,2" Spacing="6">
                            <TextBlock Text="{Binding Header}"
                                       Foreground="#DDDDEE"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="4,0,0,0"/>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ItemViewModel">
                                        <Border Width="260"
                                                Margin="6"
                                                Padding="10"
                                                Background="#141420"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                VerticalAlignment="Top">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Slot}"
                                                           Foreground="#777799"
                                                           FontSize="10"
                                                           Margin="0,0,0,1"/>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{Binding NameBrush}"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding BaseType}"
                                                           IsVisible="{Binding HasSeparateName}"
                                                           Foreground="#AAAAAA"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>
                                                <ItemsControl ItemsSource="{Binding Implicits}"
                                                              IsVisible="{Binding HasImplicits}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:ModLineViewModel">
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{Binding Brush}"
                                                                       FontSize="10"
                                                                       TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Height="1"
                                                        Background="{Binding BorderBrush}"
                                                        Margin="0,4,0,4"/>
                                                <ItemsControl ItemsSource="{Binding Body}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:ModLineViewModel">
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{Binding Brush}"
                                                                       FontSize="10"
                                                                       TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Height="1"
                                                        Background="{Binding BorderBrush}"
                                                        IsVisible="{Binding HasStatusFlags}"
                                                        Margin="0,4,0,4"/>
                                                <ItemsControl ItemsSource="{Binding StatusFlags}"
                                                              IsVisible="{Binding HasStatusFlags}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:ModLineViewModel">
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{Binding Brush}"
                                                                       FontSize="10"
                                                                       TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
