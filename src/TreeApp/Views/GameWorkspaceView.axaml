<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PathOfAvalonia.TreeApp"
             xmlns:vm="clr-namespace:PathOfAvalonia.TreeApp.ViewModels"
             x:Class="PathOfAvalonia.TreeApp.Views.GameWorkspaceView"
             x:DataType="vm:GameWorkspaceViewModel">
    <Grid Background="#101018" RowDefinitions="48,*">
        <Border Background="#15151D" BorderBrush="#30303A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="14,0" VerticalAlignment="Center">
                <TextBlock Text="PathOfAvalonia" Foreground="#F0F0F4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding GameName}" Foreground="#CFCFE0" Margin="18,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding TreeVersion, StringFormat='Tree {0}'}" Foreground="#9090A0" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <Button Grid.Column="4" Content="Change Game" Command="{Binding BackToLandingCommand}"/>
            </Grid>
        </Border>
        <TabControl Grid.Row="1" Background="#101018">
            <TabItem Header="Passive Tree">
                <Grid Name="TreeRoot" Background="#101018">
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="12" Padding="10"
                            Background="#CC1A1A24" CornerRadius="6"
                            BorderBrush="#3A3A4A" BorderThickness="1">
                        <StackPanel Orientation="Vertical" Spacing="6" Width="360" DataContext="{Binding TreePanel}">
                            <TextBlock Text="Class" Foreground="#EAEAEA" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding ClassNames}"
                                      SelectedIndex="{Binding SelectedClassIndex}"
                                      HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Ascendancy" Foreground="#EAEAEA" FontWeight="Bold"
                                       Margin="0,6,0,0"/>
                            <ComboBox ItemsSource="{Binding AscendancyNames}"
                                      SelectedItem="{Binding SelectedAscendancyName}"
                                      HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Import build" Foreground="#EAEAEA" FontWeight="Bold"
                                       Margin="0,6,0,0"
                                       IsVisible="{Binding IsImportSupported}"/>
                            <TextBlock Text="Paste a PoE tree URL or a PoB build code:"
                                       Foreground="#AAAACC" FontSize="11"
                                       IsVisible="{Binding IsImportSupported}"/>
                            <TextBox Name="ImportInput"
                                     Text="{Binding ImportInput}"
                                     AcceptsReturn="False"
                                     TextWrapping="NoWrap"
                                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                     PlaceholderText="https://www.pathofexile.com/passive-skill-tree/... or PoB code"
                                     IsVisible="{Binding IsImportSupported}">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Return" Command="{Binding ImportCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsImportSupported}">
                                <Button Content="Import" Command="{Binding ImportCommand}"/>
                                <Button Content="Clear" Command="{Binding ClearCommand}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UnsupportedImportStatus}"
                                       Foreground="#AAAACC"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding IsImportUnsupported}"/>
                            <TextBlock Text="{Binding ImportStatus}"
                                       Foreground="{Binding ImportStatusForeground}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Equipment" IsEnabled="{Binding SupportsEquipment}">
                <local:EquipmentView DataContext="{Binding Workspace.Equipment}"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
